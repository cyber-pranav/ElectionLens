# ╔════════════════════════════════════════════════════════════════╗
# ║         ElectionLens — Environment Configuration              ║
# ╚════════════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Your Google Gemini API key
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for insight generation
# Options: gemini-2.0-flash (faster) | gemini-1.5-pro (more capable)
GEMINI_MODEL=gemini-2.0-flash

# Database URL (SQLite, zero-config)
DATABASE_URL=sqlite:///./data/elections.db

# API Server Port
PORT=8000

# Streamlit Frontend Port
FRONTEND_PORT=8501
